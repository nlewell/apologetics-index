// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ApologeticIndexItem {
  id                  Int      @id @default(autoincrement())
  sourceKey           String   @unique
  generalTopic        String?
  subtopic            String?
  charge              String?
  shortResponseUrl    String?
  shortResponseLength String?
  shortResponseAuthor String?
  longResponseUrl     String?
  longResponseLength  String?
  debateUrl           String?
  articleUrl          String?
  video1Length        String?
  video1Author        String?
  video1Timestamp     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model YoutubeSearchCache {
  id        Int      @id @default(autoincrement())
  query     String   @unique
  items     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model YoutubeVideoIndex {
  id          Int      @id @default(autoincrement())
  query       String   @unique
  items       Json
  refreshedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model YoutubeChannelCache {
  id        Int      @id @default(autoincrement())
  handle    String   @unique
  channelId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model YoutubeChannelSearchCache {
  id        Int      @id @default(autoincrement())
  query     String
  channelId String
  items     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([query, channelId])
  @@index([query])
  @@index([channelId])
}

model YoutubeVideoMetadata {
  id             Int      @id @default(autoincrement())
  query          String
  videoId        String
  item           Json
  startTimestamp String?
  keepOnRefresh   Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([query, videoId])
  @@index([query])
}

model YoutubeChannelWhitelistEntry {
  id         Int      @id @default(autoincrement())
  identifier String   @unique
  isEnabled  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

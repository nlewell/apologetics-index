// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ApologeticIndexItem {
  id                  Int      @id @default(autoincrement())
  sourceKey           String   @unique
  generalTopic        String?
  subtopic            String?
  charge              String?
  shortResponseUrl    String?
  shortResponseLength String?
  shortResponseAuthor String?
  longResponseUrl     String?
  longResponseLength  String?
  debateUrl           String?
  articleUrl          String?
  video1Length        String?
  video1Author        String?
  video1Timestamp     String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

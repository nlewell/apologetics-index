{
  "expo": {
    "name": "Clarify Faith",
    "slug": "clarifying-faith-and-reason",
    "scheme": "clarifyingfaithandreason",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.clarifyingfaithandreason.mobile",
      "supportsTablet": true
    },
    "android": {
      "package": "com.clarifyingfaithandreason.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0d274d"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "versionCode": 2,
      "usesCleartextTraffic": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "f8613d7b-c3fb-424b-ad8c-4394d03fae42"
      }
    },
    "owner": "nlewell",
    "plugins": [
      "expo-font"
    ]
  }
}
